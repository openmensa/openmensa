{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:best-practices",
    ":dependencyDashboard",
    ":label(dependencies)",
  ],

  // Do not pin images in docker-compose. This one is only intended
  // for local development. Pinning makes it harder to use a locally
  // build image for testing.
  "docker-compose": {
    digest: {
      enabled: false,
    },
  },

  packageRules: [
    {
      matchUpdateTypes: [
        "minor",
        "patch",
        "pin",
        "digest",
        "lockFileMaintenance",
      ],
      automerge: true,
    },

    // Group ruby interpreter bumps for docker, ruby-version, etc. all
    // in one merge request.
    {
      matchPackageNames: ["ruby", "docker.io/ruby", "ruby/setup-ruby"],
      groupName: "ruby",
    },

    // Do not bump ruby version (only security patches). We still need
    // to coordinate these with deployment.
    {
      matchPackageNames: ["ruby", "docker.io/ruby"],
      matchUpdateTypes: ["major", "minor"],
      enabled: false,
    },

    // Do not pin or digest the base image. It is only used for local
    // development with the docker-compose.yaml, and the tag is intended
    // to be build locally.
    {
      matchPackageNames: ["ghcr.io/openmensa/openmensa"],
      enabled: false,
    },

    // Honor uv min release age
    {
      matchDatasources: ["pypi"],
      minimumReleaseAge: "14 days",
      minimumReleaseAgeBehaviour: "timestamp-required",
    },
  ],
}
